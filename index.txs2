const FAQS = [
  {
    q: "What's the cost?",
    a: "Solution packages are tailored per client based on a small percentage of expected uplift/ROI, ranging from $5k–$30k+. We like to frame this as an investment, not a cost. The true cost lies in inaction. The ROI promised is the product you receive. We stand behind our calculations with our own money, 100%.",
  },
  {
    q: "How long does the diagnostic take?",
    a: "Most diagnostics are completed within 24–48 hours after we receive your metrics and access.",
  },
  {
    q: "What do I receive?",
    a: "A written report with your projected ROI, the three highest-impact fixes, and a prioritized implementation roadmap — plus a discovery call and a 90-minute strategy call with a Loom walkthrough to go over the results.",
  },
  {
    q: "What if I want you to implement the fixes?",
    a: "We handle implementation directly. Engineering, UX, copy, and mathematical validation are included in the build phase.",
  },
  {
    q: "What if the numbers don't match?",
    a: "Our calculation model has been rigorously tested across thousands of cases. We have never had a single instance where the numbers did not hold. In the rare event you are an extreme outlier, we stand behind our projections and will continue at no extra cost until that goal is reached. With us, you pay for peace of mind: you buy the package, and you will see the ROI we promised.",
  },
  {
    q: "Is this a retainer?",
    a: "No. The diagnostic is a fixed-scope engagement. Implementation is quoted separately once we know the work.",
  },
];

function Faq() {
  const [open, setOpen] = useState<number | null>(null);

  return (
    <section className="section-shell relative">
      <div className="grid-overlay" aria-hidden />

      <div className="relative z-10 mx-auto w-full max-w-[800px]">
        <div className="mb-[34px] h-[1px] w-[55px] bg-accent-cyan" aria-hidden />

        <p className="label-mono mb-[21px] text-text-muted">Section 06 · FAQ</p>

        <h2 className="font-display text-[26px] font-bold uppercase tracking-[0.06em] text-text-primary sm:text-[34px] md:text-[42px]">
          Questions
        </h2>

        <div className="mt-[55px]">
          {FAQS.map((item, i) => {
            const isOpen = open === i;
            return (
              <div
                key={i}
                className="border-b border-border-subtle first:border-t first:border-border-subtle"
              >
                <button
                  type="button"
                  onClick={() => setOpen(isOpen ? null : i)}
                  className="flex w-full items-start justify-between gap-[21px] py-[21px] text-left"
                  aria-expanded={isOpen}
                >
                  <span className="font-display text-[16px] font-semibold uppercase tracking-[0.04em] text-text-primary sm:text-[18px]">
                    {item.q}
                  </span>
                  <span
                    className="ml-[13px] inline-flex h-[22px] w-[22px] shrink-0 items-center justify-center border border-accent-cyan text-[15px] leading-none text-accent-cyan"
                    aria-hidden
                  >
                    {isOpen ? "−" : "+"}
                  </span>
                </button>

                <div
                  className={`grid overflow-hidden transition-[grid-template-rows] duration-200 ${isOpen ? "grid-rows-[1fr]" : "grid-rows-[0fr]"}`}
                >
                  <div className="min-h-0">
                    <p className="pb-[21px] text-[15px] leading-[1.7] text-text-muted">
                      {item.a}
                    </p>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <SectionMark />
    </section>
  );
}

