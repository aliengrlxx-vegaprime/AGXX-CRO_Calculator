const STEPS = [
  { n: "01", title: "Diagnostic", desc: "Comprehensive intake, core metrics, business context." },
  { n: "02", title: "Simulation", desc: "43 validated formulas, projected loss, 3 highest-impact changes." },
  { n: "03", title: "Implementation", desc: "We build it. Directly. Our team, our oversight." },
  { n: "04", title: "Stabilization", desc: "Noise settles. Real ROI measured against projection." },
];

function HowItWorks() {
  return (
    <section className="section-shell relative">
      <div className="grid-overlay" aria-hidden />

      <div className="relative z-10 mx-auto flex w-full max-w-[1200px] flex-col">
        <div className="mb-[34px] h-[1px] w-[55px] bg-accent-cyan" aria-hidden />
        <p className="label-mono mb-[21px] text-text-muted">Section 04 · How It Works</p>
        <h2 className="font-display text-[26px] font-bold uppercase tracking-[0.06em] text-text-primary sm:text-[34px] md:text-[42px]">
          Four steps. One deterministic loop.
        </h2>

        <ol className="mt-[89px] flex flex-col gap-[55px] lg:flex-row lg:items-stretch lg:gap-0">
          {STEPS.map((s, i) => {
            const active = i === 0;
            return (
              <li key={s.n} className="relative flex flex-1 lg:flex-col">
                {/* connector — desktop: horizontal line between steps */}
                {i > 0 && (
                  <span
                    aria-hidden
                    className="absolute left-0 top-[13px] hidden h-[1px] w-full lg:block"
                    style={{ backgroundColor: "#5ce7ff", opacity: 0.4 }}
                  />
                )}
                {/* connector — mobile: vertical line above (except first) */}
                {i > 0 && (
                  <span
                    aria-hidden
                    className="absolute -top-[34px] left-[13px] block h-[34px] w-[1px] lg:hidden"
                    style={{ backgroundColor: "#5ce7ff", opacity: 0.4 }}
                  />
                )}

                <div className="flex gap-[21px] lg:flex-col lg:gap-0">
                  <span
                    aria-hidden
                    className="relative z-10 block h-[13px] w-[13px] shrink-0"
                    style={{
                      backgroundColor: active ? "#7dff4f" : "#5ce7ff",
                      boxShadow: active ? "0 0 21px rgba(125,255,79,0.55)" : "none",
                    }}
                  />
                  <div className="min-w-0 lg:mt-[34px] lg:pr-[34px]">
                    <p className="font-mono-data text-[11px] uppercase tracking-[0.18em]" style={{ color: active ? "#7dff4f" : "#5ce7ff" }}>
                      Step {s.n}
                    </p>
                    <h3 className="mt-[8px] font-display text-[20px] font-semibold uppercase tracking-[0.04em]" style={{ color: "#f3f6f8" }}>
                      {s.title}
                    </h3>
                    <p className="mt-[13px] text-[15px] leading-[1.65]" style={{ color: "#98a3af" }}>
                      {s.desc}
                    </p>
                  </div>
                </div>
              </li>
            );
          })}
        </ol>
      </div>

      <SectionMark />
    </section>
  );
}

