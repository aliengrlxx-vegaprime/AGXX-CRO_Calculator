export const Route = createFileRoute("/")({
  head: () => ({
    meta: [
      { title: "AGXX Labs — Conversion Engineering & UX Strategy" },
      {
        name: "description",
        content:
          "AGXX Labs builds revenue from your existing traffic. CRO, UX strategy, and engineering for teams that ship.",
      },
      { property: "og:title", content: "AGXX Labs — Conversion Engineering & UX Strategy" },
      {
        property: "og:description",
        content:
          "Predictive CRO and UX strategy. Mathematical models project your ROI before you commit.",
      },
      { property: "og:url", content: "https://agxxlabs.com/" },
      { name: "twitter:title", content: "AGXX Labs — Conversion Engineering & UX Strategy" },
      {
        name: "twitter:description",
        content:
          "Predictive CRO and UX strategy. Mathematical models project your ROI before you commit.",
      },
    ],
    links: [
      { rel: "canonical", href: "https://agxxlabs.com/" },
      {
        rel: "preload",
        as: "image",
        href: logoAsset.url,
        fetchpriority: "high",
      },
    ],
    scripts: [
      {
        type: "application/ld+json",
        children: JSON.stringify({
          "@context": "https://schema.org",
          "@graph": [
            {
              "@type": "Service",
              name: "Predictive CRO & UX Strategy",
              provider: { "@id": "https://agxxlabs.com/#organization" },
              serviceType: "Conversion Rate Optimization",
              areaServed: "Worldwide",
              description:
                "Deterministic CRO and UX engineering. Mathematical models project ROI before commitment, then we implement the highest-impact fixes directly.",
              offers: { "@type": "Offer", priceCurrency: "USD", priceRange: "$5000-$30000+" },
            },
            {
              "@type": "FAQPage",
              mainEntity: FAQS.map((f) => ({
                "@type": "Question",
                name: f.q,
                acceptedAnswer: { "@type": "Answer", text: f.a },
              })),
            },
          ],
        }),
      },
    ],
  }),
  component: Index,
});

function Index() {
  return (
    <main className="min-h-screen bg-canvas text-text-secondary">
      <Hero />
      <Problem />
      <Pillars />
      <HowItWorks />
      <MidCta />
      <Model />
      <Faq />
      <FinalCta />
      <Footer />
