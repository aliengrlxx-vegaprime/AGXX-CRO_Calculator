function RoiCalculator() {
  const [sessions, setSessions] = useState(50000);
  const [cr, setCr] = useState(2.0);
  const [aov, setAov] = useState(120);
  const [lift, setLift] = useState(25);
  const [investment, setInvestment] = useState(15000);

  const result = useMemo(() => {
    const crOld = cr / 100;
    const crNew = crOld * (1 + lift / 100);
    const baseline = sessions * crOld * aov;
    const projected = sessions * crNew * aov;
    const incremental = projected - baseline;
    const roi = investment > 0 ? ((incremental - investment) / investment) * 100 : 0;
    const payback = incremental > 0 ? (investment / incremental) * 12 : null;
    return { baseline, projected, incremental, roi, payback };
  }, [sessions, cr, aov, lift, investment]);

  const fmt = (n: number) =>
    n.toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 });

  return (
    <div className="border border-[#121416]/20 bg-white p-[21px] sm:p-[28px]">
      <div className="grid gap-[16px] sm:grid-cols-2">
        <Field label="Monthly sessions" value={sessions} onChange={setSessions} min={0} step={1000} />
        <Field
          label="Current conversion rate (%)"
          value={cr}
          onChange={setCr}
          min={0}
          step={0.1}
        />
        <Field label="Average order value ($)" value={aov} onChange={setAov} min={0} step={5} />
        <Field
          label="Projected lift (%)"
          value={lift}
          onChange={setLift}
          min={0}
          step={1}
        />
        <Field
          label="CRO investment ($)"
          value={investment}
          onChange={setInvestment}
          min={0}
          step={500}
        />
      </div>

      <div className="mt-[28px] grid gap-[13px] border-t border-[#121416]/15 pt-[21px] sm:grid-cols-2">
        <Result label="Baseline monthly revenue" value={fmt(result.baseline)} />
        <Result label="Projected monthly revenue" value={fmt(result.projected)} />
        <Result label="Incremental monthly revenue" value={fmt(result.incremental)} highlight />
        <Result label="Annual ROI" value={`${result.roi.toFixed(0)}%`} highlight />
        <Result
          label="Payback period"
          value={result.payback ? `${result.payback.toFixed(1)} months` : "—"}
        />
      </div>
    </div>
  );
}

function Field({
  label,
  value,
  onChange,
  min,
  step,
}: {
  label: string;
  value: number;
  onChange: (n: number) => void;
  min?: number;
  step?: number;
}) {
  const id = useId();
  return (
    <div className="flex flex-col gap-[6px]">
      <label htmlFor={id} className="font-mono-data text-[11px] uppercase tracking-[0.14em] text-[#121416]/65">
        {label}
      </label>
      <input
        id={id}
        type="number"
        value={value}
        min={min}
        step={step}
        onChange={(e) => onChange(Number(e.target.value) || 0)}
        className="border border-[#121416]/25 bg-white px-[12px] py-[10px] font-mono-data text-[15px] text-[#121416] focus:border-[#121416] focus:outline-none"
      />
    </div>
  );
}

function Result({
  label,
  value,
  highlight = false,
}: {
  label: string;
  value: string;
  highlight?: boolean;
}) {
  return (
    <div className="flex flex-col gap-[4px]">
      <span className="font-mono-data text-[10px] uppercase tracking-[0.14em] text-[#121416]/60">
        {label}
      </span>
      <span
        className={`font-display text-[20px] font-semibold tracking-[0.01em] ${
          highlight ? "text-[#121416]" : "text-[#121416]/85"
        }`}
      >
        {value}
      </span>
    </div>
  );
}
